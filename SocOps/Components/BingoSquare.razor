@using SocOps.Models

<button
    @onclick="OnClick"
    disabled="@Square.IsFreeSpace"
    class="@GetCssClasses()"
    aria-pressed="@Square.IsMarked"
    aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    <span class="square-text">@Square.Text</span>
    @if (Square.IsMarked && !Square.IsFreeSpace)
    {
        <span class="square-check">★</span>
    }
</button>

@code {
    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetCssClasses()
    {
        if (Square.IsFreeSpace)
            return "bingo-square bingo-square--free";

        if (IsWinning)
            return "bingo-square bingo-square--winning animate-glow-pulse";

        if (Square.IsMarked)
            return "bingo-square bingo-square--marked";

        return "bingo-square bingo-square--default";
    }
}
