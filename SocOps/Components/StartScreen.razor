<div class="start-screen">
    <div class="start-inner">

        <!-- Logo -->
        <div class="start-logo-wrap">
            <h1 class="start-logo animate-flicker">SOC<br/>OPS</h1>
            <p class="start-subtitle">— SOCIAL BINGO —</p>
        </div>

        <!-- Rules card -->
        <div class="start-card">
            <p class="start-card-title">HOW TO PLAY</p>
            <ul class="start-rules">
                <li><span class="rule-icon">▶</span> Find someone who matches a square</li>
                <li><span class="rule-icon">▶</span> Tap the square to mark it</li>
                <li><span class="rule-icon">▶</span> Get 5 in a row to score BINGO</li>
            </ul>
        </div>

        <!-- CTA -->
        <button @onclick="OnStart" class="start-btn">
            <span class="start-btn-arrow">▶</span> INSERT COIN
        </button>

        <p class="start-credits animate-blink">PRESS TO BEGIN</p>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
