<div class="modal-overlay">
    <div class="modal-card animate-slide-up">
        <!-- Pixel corner decorations -->
        <div class="modal-corner modal-corner--tl"></div>
        <div class="modal-corner modal-corner--tr"></div>
        <div class="modal-corner modal-corner--bl"></div>
        <div class="modal-corner modal-corner--br"></div>

        <p class="modal-player-one animate-blink">PLAYER ONE</p>
        <h2 class="modal-bingo animate-glitch">BINGO!</h2>
        <p class="modal-line">LINE COMPLETE</p>
        <div class="modal-score">+1000 PTS</div>
        <button @onclick="OnDismiss" class="modal-btn">
            <span>▶</span> KEEP PLAYING
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
