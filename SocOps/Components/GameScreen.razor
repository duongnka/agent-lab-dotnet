@using SocOps.Models

<div class="game-screen">
    <!-- Header -->
    <header class="game-header">
        <button @onclick="OnReset" class="quit-btn">
            ◀ QUIT
        </button>
        <h1 class="game-title animate-flicker">SOC OPS</h1>
        <div class="w-16"></div>
    </header>

    <!-- Instructions -->
    <p class="game-instructions">
        FIND SOMEONE WHO MATCHES · TAP TO MARK
    </p>

    <!-- Bingo banner -->
    @if (HasBingo)
    {
        <div class="bingo-banner animate-glow-pulse">
            ★ BINGO! LINE COMPLETE! ★
        </div>
    }

    <!-- Board -->
    <div class="board-wrap">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
